# Minimum runtime
POSTGRES_URL=
JWE_SECRET=

# Public origin — overrides the default OG / absolute-URL host.
# Optional; falls back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL /
# open-agents.dev. See docs/SELF_HOST_MULTITENANT.md.
NEXT_PUBLIC_APP_URL=
# Server-side alias (used in emails); falls back to NEXT_PUBLIC_APP_URL.
APP_URL=

# Required to sign in and store provider tokens
# Must be a 32-byte hex string (64 characters)
ENCRYPTION_KEY=

# Vercel OAuth (required for sign-in)
# Callback URL: {YOUR_ORIGIN}/api/auth/vercel/callback
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# GitHub App (required for repo access, pushes, and PRs)
# Callback URL: {YOUR_ORIGIN}/api/github/app/callback
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback
# In the GitHub App settings:
#   1. Enable "Request user authorization (OAuth) during installation"
#   2. Use the GitHub App Client ID and Client Secret below
#   3. Make the app public if you want org installs to work cleanly
#   4. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional deployment refinements
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=

# ---------------------------------------------------------------------------
# dot-do fork additions (multitenant)
# ---------------------------------------------------------------------------

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for each plan tier (from your Stripe dashboard)
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_ENTERPRISE=
# Optional Stripe API version override (defaults to 2024-12-18.acacia)
# STRIPE_API_VERSION=

# Email (Resend) — used for invites and quota alerts
RESEND_API_KEY=
# Default "From" address for all outbound email
EMAIL_FROM=
# Separate "From" for invite emails (falls back to EMAIL_FROM)
INVITE_FROM_EMAIL=

# Cron / scheduled jobs — bearer token checked by /api/cron/* routes
CRON_SECRET=

# Default per-tenant quotas (wave 2C). Applied when a tenant has no override.
DEFAULT_TENANT_QUOTA_MAX_SESSIONS=
DEFAULT_TENANT_QUOTA_MAX_CONCURRENT_SANDBOXES=
DEFAULT_TENANT_QUOTA_MAX_SANDBOX_MINUTES_PER_DAY=
DEFAULT_TENANT_QUOTA_MAX_TOKENS_PER_DAY=
DEFAULT_TENANT_QUOTA_MAX_REPO_CLONE_MB=

# SSO (P3, enterprise plan only — scaffold). The app ships stub adapters
# in apps/web/lib/sso/index.ts; installing a provider SDK and replacing
# the stub is a per-fork operation. Only the enterprise plan surfaces the
# Settings → SSO page (gated by assertPlanAllows(ctx, 'sso')).
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=

# Legacy-route redirect. When truthy (default), `/[username]/...` 308-redirects
# to `/t/[tenantSlug]/...` using the user's primary (oldest) tenant membership.
# Set to `false` to fall through to the original upstream `/[username]` pages
# — useful when debugging upstream merges. See docs/UPSTREAM_SYNC.md.
DISABLE_LEGACY_USERNAME_ROUTES=true

# Cross-tenant admin console (wave 6 cxg). Comma-separated list of user IDs
# allowed to access /admin and the /api/admin/* routes. Empty / unset disables
# the console entirely. Use the user's `users.id` (nanoid), not username/email.
ADMIN_USER_IDS=

# OpenTelemetry tracing (optional). When OTEL_EXPORTER_OTLP_ENDPOINT is unset
# the Node SDK is never started and withTenantTags falls back to JSON log
# lines. Headers are comma-separated k=v pairs, e.g. "authorization=Bearer xxx".
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
