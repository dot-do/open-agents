# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/open_harness

# Encryption keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your_encryption_key_here
CLI_TOKEN_ENCRYPTION_KEY=your_cli_token_encryption_key_here
JWE_SECRET=your_jwe_secret_here

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Vercel tokens (pulled via `vc env pull` and scripts/refresh-vercel-token.sh)
VERCEL_OIDC_TOKEN=
BLOB_READ_WRITE_TOKEN=
