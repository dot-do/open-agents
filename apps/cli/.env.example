# Vercel OIDC token for AI proxy (pulled via scripts/refresh-vercel-token.sh)
VERCEL_OIDC_TOKEN=

# Optional: Custom web app URL (defaults to https://app.openharness.dev or localhost:3000 in dev)
# OPEN_HARNESS_URL=http://localhost:3000

# Optional: GitHub token for Vercel sandbox operations
# GITHUB_TOKEN=

# Optional: Default sandbox repository settings
# SANDBOX_REPO_URL=
# SANDBOX_BRANCH=
# SANDBOX_NEW_BRANCH=
