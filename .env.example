# ------------------------------------------------------------------------------
# open-agents (dot-do fork) — root env template
# ------------------------------------------------------------------------------
# The web app also has its own apps/web/.env.example with the same canonical
# names. Copy this file to .env.local (or apps/web/.env.local) and fill in.
# ------------------------------------------------------------------------------

# --- Core runtime ---
POSTGRES_URL=
JWE_SECRET=
# 32-byte hex string (64 characters)
ENCRYPTION_KEY=

# --- Public origin (used by OG images, absolute URLs, Stripe return URLs) ---
# Optional. Falls back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
NEXT_PUBLIC_APP_URL=

# --- Vercel OAuth (sign-in) ---
# Callback URL: {YOUR_ORIGIN}/api/auth/vercel/callback
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# --- GitHub App (repo access, pushes, PRs) ---
# Callback URL: {YOUR_ORIGIN}/api/github/app/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
# PEM contents with escaped newlines, or base64-encoded PEM
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# --- Optional: Redis / Vercel KV (skills metadata cache) ---
REDIS_URL=
KV_URL=

# --- Optional: ElevenLabs (voice input transcription) ---
ELEVENLABS_API_KEY=

# --- Optional: Vercel deployment refinements ---
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=

# ------------------------------------------------------------------------------
# Multitenant / dot-do fork additions
# ------------------------------------------------------------------------------

# --- Public origin (non-NEXT_PUBLIC alias, used server-side in emails) ---
# Falls back to NEXT_PUBLIC_APP_URL when unset.
APP_URL=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for each plan tier (from your Stripe dashboard)
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_ENTERPRISE=
# Optional Stripe API version override (defaults to 2024-12-18.acacia)
# STRIPE_API_VERSION=

# --- Email (Resend) ---
# API key from resend.com — used for invites and quota alerts
RESEND_API_KEY=
# Default "From" address for all outbound email
EMAIL_FROM=
# Separate "From" address used specifically for invite emails (falls back to EMAIL_FROM)
INVITE_FROM_EMAIL=

# --- Cron / scheduled jobs ---
# Bearer token checked by /api/cron/* routes (e.g. Vercel Cron)
CRON_SECRET=

# --- Admin ---
# Comma-separated user IDs (nanoid) allowed to access /admin routes.
# Empty / unset disables the admin console entirely.
ADMIN_USER_IDS=

# --- Legacy route redirect ---
# When truthy (default "true"), /[username]/... 308-redirects to /t/[tenantSlug]/...
# Set to "false" to keep original upstream /[username] pages.
DISABLE_LEGACY_USERNAME_ROUTES=true

# --- Observability (OpenTelemetry) ---
# When OTEL_EXPORTER_OTLP_ENDPOINT is unset the Node SDK is never started.
# Headers are comma-separated k=v pairs, e.g. "authorization=Bearer xxx".
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# --- SSO (P3, enterprise plan only — scaffold) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=

# --- Default tenant quotas (wave 2C) ---
# Per-tenant ceilings applied when a tenant row has no explicit override.
# All counts are integers; durations are seconds.
DEFAULT_TENANT_QUOTA_MAX_SESSIONS=
DEFAULT_TENANT_QUOTA_MAX_CONCURRENT_SANDBOXES=
DEFAULT_TENANT_QUOTA_MAX_SANDBOX_MINUTES_PER_DAY=
DEFAULT_TENANT_QUOTA_MAX_TOKENS_PER_DAY=
DEFAULT_TENANT_QUOTA_MAX_REPO_CLONE_MB=
